# Python virtual environment
.venv/
__pycache__/
*.pyc

# Companion guide documents (do not commit by default)
# Exception: docs/companion-guides/ is explicitly allowed (public reference docs)
**/*.pdf
**/*.docx
!docs/companion-guides/*.pdf
!docs/companion-guides/*.docx

# macOS
.DS_Store

# Real EDI files — never commit PHI data
# Only synthetic/de-identified files belong in public/sample-data/
*.edi.real

# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across editors and OSes.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,txt}]
trim_trailing_whitespace = false

# EDI files use ~ as segment terminator; never alter whitespace or line endings
[*.edi]
trim_trailing_whitespace = false
insert_final_newline = false

[*.{pdf,xlsx,png,jpg,ico,woff,woff2}]
insert_final_newline = false
